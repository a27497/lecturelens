# LectureLens local no-key Demo environment.
# Copy to .env.demo.local. These values are for local Docker services only.
# Demo mode never calls an external ASR or LLM service.

APP_PORT=8080
COURSE_LINGO_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8080

# Demo host ports intentionally avoid common local-service conflicts. Change these in .env.demo.local if needed.
MYSQL_HOST_PORT=13306
REDIS_HOST_PORT=16379
MINIO_API_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
ROCKETMQ_NAMESRV_HOST_PORT=19876
ROCKETMQ_PROXY_HOST_PORT=18081
ROCKETMQ_BROKER_FAST_HOST_PORT=20909
ROCKETMQ_BROKER_MAIN_HOST_PORT=20911
ROCKETMQ_BROKER_HA_HOST_PORT=20912

# MySQL / Flyway
MYSQL_ROOT_PASSWORD=change-me-demo-mysql-root-password
MYSQL_DATABASE=courselingo
MYSQL_USERNAME=courselingo
MYSQL_PASSWORD=change-me-demo-mysql-password
MYSQL_PORT=13306
MYSQL_JDBC_URL=jdbc:mysql://localhost:13306/courselingo?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
FLYWAY_ENABLED=true
DB_HEALTH_ENABLED=true

# Redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=change-me-demo-redis-password
REDIS_DATABASE=0

# MinIO
MINIO_ROOT_USER=change-me-demo-minio-user
MINIO_ROOT_PASSWORD=change-me-demo-minio-password
MINIO_BUCKET_RAW=courselingo-raw
MINIO_BUCKET_ARTIFACT=courselingo-artifact
MINIO_ENDPOINT=http://localhost:19000
STORAGE_MINIO_ENDPOINT=http://localhost:19000
STORAGE_MINIO_ACCESS_KEY=change-me-demo-minio-user
STORAGE_MINIO_SECRET_KEY=change-me-demo-minio-password
STORAGE_MINIO_BUCKET=courselingo-artifact
STORAGE_MINIO_REGION=

# RocketMQ
ROCKETMQ_ENABLED=true
ROCKETMQ_NAME_SERVER=127.0.0.1:19876
ROCKETMQ_ENDPOINT=127.0.0.1:18081
ROCKETMQ_PRODUCER_GROUP=lecturelens-demo-producer-group
ROCKETMQ_CONSUMER_GROUP=lecturelens-demo-consumer-group
ROCKETMQ_ANALYSIS_TOPIC=courselingo-analysis-task
ROCKETMQ_SSL_ENABLED=false

# Local authentication and media processing
JWT_ACCESS_SECRET=change-me-demo-jwt-secret-at-least-32-characters
JWT_ACCESS_EXPIRE_SECONDS=3600
JWT_REFRESH_EXPIRE_SECONDS=2592000
FFMPEG_EXECUTABLE=ffmpeg
FFMPEG_AUDIO_FORMAT=wav
FFMPEG_SAMPLE_RATE=16000
FFMPEG_CHANNELS=1
FFMPEG_TIMEOUT_SECONDS=300

# Real asynchronous pipeline with local deterministic AI providers
COURSELINGO_TASK_RUNNER_PIPELINE_ENABLED=true
DISPATCH_EXECUTOR_TASK_TIMEOUT_SECONDS=900
MOCK_ASR_ENABLED=true
MOCK_ASR_DEFAULT_LANGUAGE=en-US
MOCK_ASR_DEFAULT_TEXT=Welcome to the LectureLens local demo course. This sample explains an asynchronous course video learning pipeline.
MOCK_ASR_SEGMENT_DURATION_MILLIS=12000
DEMO_MOCK_LLM_ENABLED=true
SILICONFLOW_ASR_ENABLED=false
SILICONFLOW_API_KEY=
SILICONFLOW_ASR_BASE_URL=http://127.0.0.1:9
OPENAI_COMPATIBLE_ENABLED=false
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:9
LANGCHAIN4J_OPENAI_ENABLED=false
LANGCHAIN4J_OPENAI_API_KEY=
LANGCHAIN4J_OPENAI_BASE_URL=http://127.0.0.1:9

# Keep optional visual providers off in the no-key Demo.
COURSELINGO_VISION_KEYFRAME_ENABLED=false
COURSELINGO_VISION_OCR_ENABLED=false
COURSELINGO_VISION_ANALYSIS_ENABLED=false
COURSELINGO_FUSION_VIDEO_SEGMENT_ENABLED=false
COURSELINGO_SUBTITLE_TRANSLATION_FULL_TEXT_ENABLED=true
