# LectureLens local real-AI environment template.
# Copy to .env, fill your own local values, and never commit that file.
# Do not paste keys into issues, logs, screenshots, or shell history.

# MySQL
MYSQL_HOST_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
MYSQL_DATABASE=courselingo
MYSQL_USERNAME=courselingo
MYSQL_PASSWORD=change-me-mysql-password
MYSQL_JDBC_URL=jdbc:mysql://localhost:3306/courselingo?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
FLYWAY_ENABLED=true

# Redis
REDIS_HOST_PORT=6379
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password

# MinIO
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET_RAW=courselingo-raw
MINIO_BUCKET_ARTIFACT=courselingo-artifact
STORAGE_MINIO_ENDPOINT=http://localhost:9000
STORAGE_MINIO_ACCESS_KEY=change-me-minio-user
STORAGE_MINIO_SECRET_KEY=change-me-minio-password
STORAGE_MINIO_BUCKET=courselingo-artifact

# RocketMQ
ROCKETMQ_NAMESRV_HOST_PORT=19876
ROCKETMQ_PROXY_HOST_PORT=8081
ROCKETMQ_BROKER_FAST_HOST_PORT=10909
ROCKETMQ_BROKER_MAIN_HOST_PORT=10911
ROCKETMQ_BROKER_HA_HOST_PORT=10912
ROCKETMQ_ENABLED=true
ROCKETMQ_NAME_SERVER=127.0.0.1:19876
ROCKETMQ_ENDPOINT=127.0.0.1:8081
ROCKETMQ_PRODUCER_GROUP=courselingo-analysis-producer-group
ROCKETMQ_CONSUMER_GROUP=courselingo-analysis-consumer-group
ROCKETMQ_ANALYSIS_TOPIC=courselingo-analysis-task

# JWT / FFmpeg / Pipeline
JWT_ACCESS_SECRET=change-me-jwt-secret-at-least-32-characters
FFMPEG_EXECUTABLE=ffmpeg
COURSELINGO_TASK_RUNNER_PIPELINE_ENABLED=true

# SiliconFlow ASR: apply for your own key and keep it only in the local .env file.
SILICONFLOW_ASR_ENABLED=true
SILICONFLOW_API_KEY=change-me-siliconflow-api-key
SILICONFLOW_ASR_BASE_URL=https://api.siliconflow.cn
SILICONFLOW_ASR_MODEL=FunAudioLLM/SenseVoiceSmall

# OpenAI-compatible LLM: use credentials issued to you by your selected provider.
OPENAI_COMPATIBLE_ENABLED=true
OPENAI_COMPATIBLE_API_KEY=change-me-openai-compatible-api-key
OPENAI_COMPATIBLE_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_COMPATIBLE_MODEL=Qwen/Qwen2.5-7B-Instruct

# Disable the local Demo providers in real-AI mode.
MOCK_ASR_ENABLED=false
DEMO_MOCK_LLM_ENABLED=false
